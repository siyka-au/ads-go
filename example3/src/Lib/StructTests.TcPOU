<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="StructTests" Id="{b1c2d3e4-0000-4000-8000-000000000001}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK StructTests
VAR
	seed       : UDINT;
	pack_none  : PackNone;
	pack_two   : PackTwo;
	pack_four  : PackFour;
	pack_eight : PackEight;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// All four structs share the same fields and the same seed-driven formula.
// b1  = (seed MOD 2 = 0)
// d1  = seed
// b2  = (seed MOD 3 = 0)
// lw1 = LWORD(seed) * LWORD(3)
pack_none.b1  := (seed MOD 2 = 0);
pack_none.d1  := seed;
pack_none.b2  := (seed MOD 3 = 0);
pack_none.lw1 := UDINT_TO_LWORD(seed) * UDINT_TO_LWORD(3);

pack_two.b1  := pack_none.b1;
pack_two.d1  := pack_none.d1;
pack_two.b2  := pack_none.b2;
pack_two.lw1 := pack_none.lw1;

pack_four.b1  := pack_none.b1;
pack_four.d1  := pack_none.d1;
pack_four.b2  := pack_none.b2;
pack_four.lw1 := pack_none.lw1;

pack_eight.b1  := pack_none.b1;
pack_eight.d1  := pack_none.d1;
pack_eight.b2  := pack_none.b2;
pack_eight.lw1 := pack_none.lw1;]]></ST>
    </Implementation>
    <LineIds Name="StructTests">
      <LineId Id="2" Count="0" />
      <LineId Id="4" Count="22" />
    </LineIds>
  </POU>
</TcPlcObject>