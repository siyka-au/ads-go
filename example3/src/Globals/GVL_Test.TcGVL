<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.21">
  <GVL Name="GVL_Test" Id="{0636CC42-27A5-4813-A981-10BAFB034F62}">
    <Declaration><![CDATA[{attribute 'qualified_only'}
VAR_GLOBAL
	// -----------------------------------------------------------------------
	// Control variables — writable by Go test
	// -----------------------------------------------------------------------

	// Driving seed: all output variables are a deterministic function of this.
	seed               : UDINT := 0;

	// FALSE = Go controls seed via ADS write (static test mode).
	// TRUE  = PLC auto-increments seed every auto_tick_interval cycles
	//         (subscription / dynamic test mode).
	auto_mode          : BOOL := FALSE;

	// Number of PLC cycles between seed increments in auto_mode (default 50 = 500 ms at 10 ms cycle).
	auto_tick_interval : UDINT := 50;

	// -----------------------------------------------------------------------
	// Output variables — read-only by Go test
	// -----------------------------------------------------------------------

	// Snapshot of all scalar types, updated atomically each cycle from seed.
	snapshot           : ST_Snapshot;

	// 1-D arrays: element[i] = f(seed + i)
	v_int_array        : ARRAY[0..9] OF INT;
	v_dint_array       : ARRAY[0..9] OF DINT;

	// 2-D array: element[i,j] = f(seed + i*3 + j)
	v_2d_array         : ARRAY[0..2, 0..2] OF INT;
END_VAR]]></Declaration>
  </GVL>
</TcPlcObject>
