# Copy this file to .env and fill in your values.
# The CLI (cmd/main.go) reads these via os.Getenv; integration tests load
# this file automatically via godotenv (see TESTING.md for search order).

# AMS NetID of the target TwinCAT runtime (required)
ADS_TARGET_NET_ID=127.0.0.1.1.1

# Hostname or IP of the AMS router (default: 127.0.0.1)
ADS_ROUTER_HOST=127.0.0.1

# TCP port of the AMS router (default: 48898)
ADS_ROUTER_PORT=48898

# Per-message read/write timeout, Go duration format (default: 2s)
ADS_TIMEOUT=2s
